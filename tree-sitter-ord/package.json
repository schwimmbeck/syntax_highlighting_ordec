{
  "name": "tree-sitter-ord",
  "version": "0.0.1",
  "description": "ord grammar for tree-sitter",
  "license": "MIT AND Apache-2.0",
  "main": "bindings/node",
  "files": [
    "Cargo.toml",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md",
    "binding.gyp",
    "bindings/node/*",
    "bindings/rust/*",
    "grammar.js",
    "package.json.license",
    "queries/*",
    "src/*",
    "tree-sitter.json",
    "tree-sitter.json.license"
  ],
  "keywords": [
    "parsing",
    "incremental"
  ],
  "dependencies": {
    "nan": "^2.12.1"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.20.8"
  },
  "scripts": {
    "test": "npm run test:corpus && npm run test:queries",
    "test:corpus": "tree-sitter test",
    "test:queries": "bash ./scripts/validate-queries.sh"
  }
}
