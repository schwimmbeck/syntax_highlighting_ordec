{
  "scopeName": "source.ord.injection",
  "injectionSelector": "L:source.ord",
  "comment": "ORD-specific rules injected with higher priority (L:) into the ORD base grammar, which delegates to Python. This mirrors the Sublime Text approach where ORD extends Python syntax.",
  "patterns": [
    { "include": "#cell-declaration" },
    { "include": "#viewgen-declaration" },
    { "include": "#context-element" },
    { "include": "#path-net" },
    { "include": "#number-si-float" },
    { "include": "#number-si-integer" },
    { "include": "#number-rational" },
    { "include": "#parameter-access" },
    { "include": "#connect-operator" },
    { "include": "#constrain-operator" }
  ],
  "repository": {
    "cell-declaration": {
      "comment": "cell Name: or cell Name(Base):",
      "begin": "\\s*(cell)\\s+(?=[_[:alpha:]]\\w*\\s*[:(])",
      "beginCaptures": {
        "1": { "name": "storage.type.class.python" }
      },
      "end": "(:)|$",
      "endCaptures": {
        "1": { "name": "punctuation.section.class.begin.python" }
      },
      "name": "meta.class.ord",
      "patterns": [
        {
          "begin": "\\(",
          "beginCaptures": { "0": { "name": "punctuation.definition.inheritance.begin.python" } },
          "end": "\\)",
          "endCaptures": { "0": { "name": "punctuation.definition.inheritance.end.python" } },
          "patterns": [
            { "include": "source.python" }
          ]
        },
        {
          "match": "\\b([_[:alpha:]]\\w*)\\b",
          "name": "entity.name.type.class.python"
        }
      ]
    },

    "viewgen-declaration": {
      "comment": "viewgen name(args) -> Type:",
      "begin": "\\s*(viewgen)\\s+([_[:alpha:]]\\w*)\\s*(?=\\(|->|:)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.function.ord" },
        "2": { "name": "entity.name.function.python" }
      },
      "end": "(:)|$",
      "endCaptures": {
        "1": { "name": "punctuation.section.function.begin.python" }
      },
      "name": "meta.function.ord",
      "patterns": [
        {
          "begin": "\\(",
          "beginCaptures": { "0": { "name": "punctuation.definition.parameters.begin.python" } },
          "end": "\\)",
          "endCaptures": { "0": { "name": "punctuation.definition.parameters.end.python" } },
          "patterns": [
            { "include": "source.python" }
          ]
        },
        {
          "match": "(->)\\s*([_[:alpha:]]\\w*)",
          "captures": {
            "1": { "name": "punctuation.separator.return-type.python" },
            "2": { "name": "entity.name.type.class.python" }
          }
        }
      ]
    },

    "context-element": {
      "comment": "Context elements: Nmos m1:, inout vdd:, port ctr[i]:",
      "begin": "(?!(?:and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|cell|viewgen|path|net)\\b)(?=([_[:alpha:]]\\w*)\\s+([_[:alpha:]]\\w*)(?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\])*\\s*:)",
      "end": "(:)|$",
      "endCaptures": {
        "1": { "name": "punctuation.section.block.begin.ord" }
      },
      "name": "meta.context-element.ord",
      "patterns": [
        {
          "match": "\\b(inout|input|output|port)\\b",
          "name": "storage.type.ord"
        },
        {
          "match": "(?:^|(?<=\\s))([_[:alpha:]]\\w*)(?=\\s+[_[:alpha:]])",
          "name": "entity.name.type.class.python"
        },
        {
          "match": "\\[",
          "name": "punctuation.section.brackets.begin.ord"
        },
        {
          "match": "\\]",
          "name": "punctuation.section.brackets.end.ord"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.dot.ord"
        },
        {
          "match": "[_[:alpha:]]\\w*",
          "name": "variable.other.readwrite.python"
        }
      ]
    },

    "path-net": {
      "comment": "path/net declarations: path ctr, net vdd, vss",
      "begin": "\\b(path|net)(?=\\s+[_[:alpha:]]\\w*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.ord" }
      },
      "end": "$",
      "name": "meta.path-net.ord",
      "patterns": [
        { "match": "[_[:alpha:]]\\w*", "name": "variable.other.ord" },
        { "match": ",", "name": "punctuation.separator.ord" }
      ]
    },

    "number-si-float": {
      "comment": "Float with SI suffix: 1.5u, 3.14n, 1e-3k",
      "match": "(?<!\\w)(?:(?:\\.[0-9](?:_?[0-9])*|[0-9](?:_?[0-9])*\\.[0-9](?:_?[0-9])*|[0-9](?:_?[0-9])*\\.)(?:[Ee][-+]?[0-9](?:_?[0-9])*)?|[0-9](?:_?[0-9])*[Ee][-+]?[0-9](?:_?[0-9])*)([afpnumkMGT])\\b",
      "captures": {
        "1": { "name": "constant.numeric.suffix.ord" }
      },
      "name": "constant.numeric.float.python"
    },

    "number-si-integer": {
      "comment": "Integer with SI suffix: 100n, 20u, 1M",
      "match": "(?<![.\\w])(?:[1-9](?:_?[0-9])*|0+)([afpnumkMGT])\\b",
      "captures": {
        "1": { "name": "constant.numeric.suffix.ord" }
      },
      "name": "constant.numeric.dec.python"
    },

    "number-rational": {
      "comment": "Rational numbers: 1/3, 100/7",
      "match": "(?<![.\\w])(?:[1-9](?:_?[0-9])*|0+)(/(?:[1-9](?:_?[0-9])*|0+))\\b",
      "captures": {
        "1": { "name": "keyword.operator.arithmetic.python" }
      },
      "name": "constant.numeric.rational.ord"
    },

    "parameter-access": {
      "comment": "Parameter access: .$param",
      "match": "(\\.)(\\$)([_[:alpha:]]\\w*)",
      "captures": {
        "1": { "name": "punctuation.accessor.dot.ord" },
        "2": { "name": "keyword.operator.parameter.ord" },
        "3": { "name": "variable.other.member.ord" }
      }
    },

    "connect-operator": {
      "comment": "Connection operator: --",
      "match": "--",
      "name": "keyword.operator.connect.ord"
    },

    "constrain-operator": {
      "comment": "Constrain operator: ! (but not !=)",
      "match": "!(?!=)",
      "name": "keyword.operator.constrain.ord"
    }
  }
}
